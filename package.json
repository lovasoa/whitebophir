{
  "name": "whitebophir",
  "description": "Online collaborative whiteboard",
  "version": "1.28.1",
  "keywords": [
    "collaborative",
    "whiteboard"
  ],
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "handlebars": "^4.7.7",
    "jsonwebtoken": "^9.0.0",
    "serve-static": "^2.2.0",
    "socket.io": "^4"
  },
  "scripts": {
    "prepare": "node scripts/install-git-hooks.js",
    "start": "node ./server/server.js",
    "bench": "node --expose-gc ./scripts/benchmark-server.js",
    "test-node": "WBO_SILENT=true node --test test-node/*.test.js",
    "test:pw": "node scripts/check-playwright-tests.js && playwright test",
    "test:pw:headed": "node scripts/check-playwright-tests.js && playwright test --headed",
    "test:pw:ui": "node scripts/check-playwright-tests.js && playwright test --ui",
    "test:pw:debug": "node scripts/check-playwright-tests.js && playwright test --debug",
    "typecheck:pw": "tsc -p tsconfig.playwright.json",
    "test": "npm run test-node && npm run test:pw && npm run prettier-check",
    "typecheck": "tsc -p tsconfig.checkjs.json",
    "format-staged": "node scripts/prettier-staged.js",
    "prettier": "prettier . --write",
    "prettier-check": "prettier . --check"
  },
  "main": "./server/server.js",
  "repository": {
    "type": "git",
    "url": "http://github.com/lovasoa/whitebophir.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "prettier": "^3.1.0",
    "typescript": "^6.0.2"
  }
}
