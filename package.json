{
  "name": "whitebophir",
  "description": "Online collaborative whiteboard",
  "version": "2.6.1",
  "keywords": [
    "collaborative",
    "whiteboard"
  ],
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.28.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "handlebars": "^4.7.7",
    "jsonwebtoken": "^9.0.0",
    "serve-static": "^2.2.0",
    "socket.io": "^4"
  },
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "start": "node ./server/server.mjs",
    "bench": "node --expose-gc ./scripts/benchmark-server.mjs",
    "bench:e2e": "npm run bench -- e2e",
    "bench:load": "npm run bench -- load",
    "bench:persist": "npm run bench -- persist",
    "bench:broadcast": "npm run bench -- broadcast",
    "profile": "node ./scripts/profile-benchmark-server.mjs",
    "generateload": "node ./scripts/generateload.mjs",
    "lint": "biome check . --assist-enabled=false --error-on-warnings",
    "format": "biome check . --write --unsafe --assist-enabled=false",
    "test-node": "WBO_SILENT=true node --test test-node/*.test.js",
    "test:pw": "node scripts/check-playwright-tests.mjs && playwright test",
    "test:pw:headed": "node scripts/check-playwright-tests.mjs && playwright test --headed",
    "test:pw:ui": "node scripts/check-playwright-tests.mjs && playwright test --ui",
    "test:pw:debug": "node scripts/check-playwright-tests.mjs && playwright test --debug",
    "typecheck:pw": "tsc -p tsconfig.playwright.json",
    "test": "npm run test-node && npm run test:pw && npm run lint",
    "typecheck": "tsc -p tsconfig.checkjs.json",
    "format-staged": "node scripts/biome-staged.mjs"
  },
  "main": "./server/server.mjs",
  "repository": {
    "type": "git",
    "url": "http://github.com/lovasoa/whitebophir.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
