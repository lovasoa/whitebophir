{
  "name": "whitebophir",
  "description": "Online collaborative whiteboard",
  "version": "1.27.1",
  "keywords": [
    "collaborative",
    "whiteboard"
  ],
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "accept-language-parser": "^1.5.0",
    "async-mutex": "^0.5.0",
    "handlebars": "^4.7.7",
    "jsonwebtoken": "^9.0.0",
    "serve-static": "^2.2.0",
    "socket.io": "^4",
    "statsd-client": "^0.4.7"
  },
  "scripts": {
    "prepare": "node scripts/install-git-hooks.js",
    "start": "node ./server/server.js",
    "bench": "node --expose-gc ./scripts/benchmark-server.js",
    "test-node": "WBO_SILENT=true node --test test-node/*.test.js",
    "test": "npm run test-node && WBO_SILENT=true nightwatch tests",
    "typecheck": "tsc -p tsconfig.checkjs.json",
    "format-staged": "node scripts/prettier-staged.js",
    "prettier": "prettier . --write",
    "prettier-check": "prettier . --check"
  },
  "main": "./server/server.js",
  "repository": {
    "type": "git",
    "url": "http://github.com/lovasoa/whitebophir.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "geckodriver": "^6.1.0",
    "nightwatch": "^3.2.1",
    "prettier": "^3.1.0",
    "typescript": "^6.0.2"
  }
}
