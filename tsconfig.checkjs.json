{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node"
  },
  "include": [
    "types/**/*.d.ts",
    "server/**/*.js",
    "scripts/**/*.js",
    "test-node/**/*.js"
  ],
  "exclude": [
