{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowUmdGlobalAccess": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true,
    "strict": true
  },
  "include": [
    "types/**/*.d.ts",
    "client-data/js/board.js",
    "client-data/js/board_page_state.js",
    "client-data/js/board_transport.js",
    "client-data/js/index.js",
    "client-data/js/message_common.js",
    "client-data/tools/clear/clear.js",
    "client-data/tools/download/download.js",
    "client-data/tools/cursor/cursor.js",
    "client-data/tools/eraser/eraser.js",
    "client-data/tools/grid/grid.js",
    "client-data/tools/hand/hand.js",
    "client-data/tools/line/line.js",
    "client-data/tools/pencil/pencil.js",
    "client-data/tools/rect/rect.js",
    "client-data/tools/ellipse/ellipse.js",
    "client-data/tools/zoom/zoom.js",
    "client-data/tools/pencil/wbo_pencil_point.js",
    "client-data/tools/text/text.js",
    "server/configuration.js",
    "server/configuration_helpers.js",
    "server/client_configuration.js",
    "server/check_output_directory.js",
    "server/createSVG.js",
    "server/jwtBoardnameAuth.js",
    "server/message_validation.js",
    "server/boardData.js",
    "server/server.js",
    "server/socket_policy.js",
    "server/sockets.js",
    "server/templating.js",
    "test-node/test_helpers.js",
    "test-node/message_common.test.js",
    "test-node/message_validation.test.js",
    "test-node/board_data.test.js",
    "test-node/board_connection.test.js",
    "test-node/board_bootstrap.test.js",
    "test-node/board_messages.test.js",
    "test-node/board_state.test.js",
    "test-node/board_tools.test.js",
    "test-node/board_turnstile.test.js",
    "test-node/create_svg.test.js",
    "test-node/socket_policy.test.js",
    "test-node/rate_limits.test.js",
    "test-node/server_routes.test.js",
    "test-node/templating.test.js",
    "test-node/turnstile.test.js"
  ],
  "exclude": ["node_modules", "server-data"]
}
